{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:base",
    "group:recommended"
  ],
  "ignorePresets": [
    ":prHourlyLimit2"
  ],
  "platformAutomerge": true,
  "packageRules": [
    {
      "groupName": "arti deps",
      "matchPackageNames": [
        "arti-client",
        "tor-rtcompat"
      ]
    },
    {
      "matchUpdateTypes": [
        "minor",
        "patch",
        "pin",
        "digest"
      ],
      "automerge": true
    }
  ],
  "lockFileMaintenance": {
    "enabled": true,
    "automerge": true
  }
}
